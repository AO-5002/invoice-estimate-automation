# =============================================================================
# Invoice Automation — server config (READ PATH)
#
# Copy to `server/.env` (gitignored) and fill in real values, OR export these as
# real environment variables. application.properties reads each one via
# ${ENV_VAR:default}. NEVER commit real values — .env and key files are gitignored.
# =============================================================================

# --- Google service-account credentials -------------------------------------
# Provide EXACTLY ONE of the following two. The service account must have at
# least Viewer access to the target spreadsheet.
#
# (A) Path to the downloaded service-account JSON key file (local/dev):
GOOGLE_CREDENTIALS_PATH=./secrets/service-account.json
#
# (B) OR the full key JSON inline on a single line (deploys that can't mount a
#     file). Leave PATH empty if you use this. SECRET — never commit.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com", ...}

# --- Google Sheets target ----------------------------------------------------
# Spreadsheet ID — the long token in the sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here
# Tab (worksheet) names. Defaults shown; override if your tabs are named differently.
SHEETS_INVOICES_TAB=Invoices
SHEETS_ESTIMATES_TAB=Estimates

# --- In-memory cache ---------------------------------------------------------
# Seconds a fetched list is served before the next request re-fetches. Default 60.
CACHE_TTL_SECONDS=60

# --- CORS --------------------------------------------------------------------
# Browser origin of the Next.js client allowed to call the API. Default below.
CORS_ALLOWED_ORIGIN=http://localhost:3000
